digraph "Observer"
{
 // INTERACTIVE_SVG=YES
 // LATEX_PDF_SIZE
  graph [fontname=Helvetica, fontsize=10];
  edge [fontname=Ubuntu labelfontsize=10 arrowhead=open arrowtail=open arrowsize=0.5];
  node [fontname=Ubuntu fontsize=12 shape=plaintext];
  Node1 [label=<<b>Observer</b>> tooltip="is virtual observer of a Subject" ];
  Node1 -> Node2 [dir="back",color="midnightblue"style="solid"];
  Node2 [label="View" URL="$structView.html" tooltip="is concrete Observer" ];
}
