digraph "Member"
{
 // INTERACTIVE_SVG=YES
 // LATEX_PDF_SIZE
  graph [fontname=Helvetica, fontsize=10];
  edge [fontname=Ubuntu labelfontsize=10 arrowhead=open arrowtail=open arrowsize=0.5];
  node [fontname=Ubuntu fontsize=12 shape=plaintext];
  Node1 [label=<<b>Member</b>> tooltip=" " ];
  Node2 -> Node1 [dir="back",color="darkorchid3"style="dashed",label=" mediator" ];
  Node2 [label="Mediator" URL="$structMediator.html" tooltip=" " ];
}
