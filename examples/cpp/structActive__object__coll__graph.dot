digraph "Active_object"
{
 // INTERACTIVE_SVG=YES
 // LATEX_PDF_SIZE
  graph [fontname=Helvetica, fontsize=10];
  edge [fontname=Ubuntu labelfontsize=10 arrowhead=open arrowtail=open arrowsize=0.5];
  node [fontname=Ubuntu fontsize=12 shape=plaintext];
  Node1 [label=<<b>Active_object</b>> tooltip="Active object" ];
  Node2 -> Node1 [dir="back",color="midnightblue"style="solid"];
  Node2 [label="Interface" URL="$structInterface.html" tooltip="is a common pure virtual interface" ];
  Node2 -> Node1 [dir="back",color="darkorchid3"style="dashed",label=" subject" ];
}
